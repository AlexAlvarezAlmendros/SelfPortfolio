---
import { getCollection, type CollectionEntry } from 'astro:content';
import type { Lang } from '../../i18n/ui';
import { useTranslations, localizePath } from '../../i18n/utils';
import { projectThumb, grid } from '../../lib/patterns';
import { projectShot } from '../../lib/project-thumbs';

interface Props {
  lang: Lang;
  entry: CollectionEntry<'projects'>;
}
const { lang, entry } = Astro.props;
const t = useTranslations(lang);
const d = entry.data;

const others = (await getCollection('projects', (e) => e.data.lang === lang && e.data.slug !== d.slug)).sort(
  (a, b) => a.data.order - b.data.order,
);

const thumb = projectThumb[d.slug] ?? grid;
const shot = projectShot[d.slug];
const shotStyle = shot
  ? `background-image:url("${shot}");background-size:cover;background-position:top center`
  : `background:${thumb}`;
const features = d.features.map((text, i) => ({ n: `0${i + 1}`, text }));
---
<main>
  <div class="wrap">
    <a class="back brd-hl" href={localizePath('/', lang)}>← {t('back.home')}</a>
    <div class="kicker">{d.label} · {d.year}</div>
    <h1 class="name" data-fit data-max="110">{d.name}</h1>
    <p class="tagline">{d.tagline}</p>
    <div class="actions">
      <a class="btn-acid btn-push" href={d.live} target="_blank" rel="noopener">{t('visit.site')} ↗</a>
      <a class="btn-ghost brd-hl" href={d.repo} target="_blank" rel="noopener">{t('view.repo')}</a>
    </div>

    <div class:list={['shot-main', { wip: !shot }]} style={shotStyle}>
      {shot
        ? <span>// {t('screenshot')} — {d.url}</span>
        : <span class="wip">// WIP · {d.year}</span>}
    </div>

    <div class="g-projmeta meta">
      <div>
        <div class="block">
          <div class="lbl">{t('role')}</div>
          <div class="val">{d.role}</div>
        </div>
        <div>
          <div class="lbl">{t('stack')}</div>
          <div class="tags">
            {d.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </div>
      </div>
      <div>
        <h2 class="h">{t('overview')}</h2>
        <p class="ov">{d.overview}</p>
        <h2 class="h">{t('key.features')}</h2>
        <div class="features">
          {features.map((f) => (
            <div class="feat">
              <span class="feat-n">{f.n}</span>
              <span class="feat-t">{f.text}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="next">
      {others.map((op) => (
        <a class="next-a lnk" href={localizePath(`/work/${op.data.slug}`, lang)}>{t('next.project')} → {op.data.name}</a>
      ))}
    </div>
  </div>
</main>

<style>
  main { min-height: 90vh; position: relative; z-index: 2; padding: 40px 26px 100px; }
  .wrap { max-width: 1180px; margin: 0 auto; }
  .back { display: inline-block; background: none; border: 1px solid #2a2a26; color: #a8a69d; font-family: 'Space Mono', monospace; font-size: 11px; padding: 8px 13px; margin-bottom: 28px; text-decoration: none; }
  .kicker { font-family: 'Space Mono', monospace; font-size: 11px; color: #ccff00; margin-bottom: 14px; }
  .name { font-family: 'Syne Variable', sans-serif; font-weight: 800; font-size: clamp(40px, 8vw, 110px); margin: 0 0 18px; letter-spacing: -0.03em; line-height: 0.9; white-space: nowrap; }
  .tagline { font-family: 'Syne Variable', sans-serif; font-size: clamp(18px, 2.2vw, 28px); font-weight: 500; color: #cfcdc4; max-width: 640px; line-height: 1.32; margin: 0 0 26px; }
  .actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 40px; }
  .btn-acid { background: #ccff00; color: #070706; font-family: 'Space Mono', monospace; font-weight: 700; font-size: 12px; padding: 12px 18px; text-decoration: none; }
  .btn-ghost { background: transparent; color: #f2f0ea; border: 1px solid #2a2a26; font-family: 'Space Mono', monospace; font-size: 12px; padding: 12px 18px; text-decoration: none; }
  /* main shot keeps the real screenshot aspect ratio (1200x630) — never crops */
  .shot-main { aspect-ratio: 1200 / 630; border: 1px solid #1d1d1a; margin-bottom: 60px; display: flex; align-items: flex-end; padding: 16px; }
  .shot-main span { font-family: 'Space Mono', monospace; font-size: 11px; color: #ccff00; background: rgba(7,7,6,0.6); padding: 3px 7px; max-width: 100%; overflow-wrap: anywhere; }
  /* placeholder state for projects without a live screenshot */
  .shot-main.wip { align-items: center; justify-content: center; }
  .shot-main.wip span { background: none; font-size: 13px; letter-spacing: 0.12em; color: #ccff00; }
  .meta { border-top: 1px solid #2a2a26; padding-top: 40px; }
  .block { margin-bottom: 28px; }
  .lbl { font-family: 'Space Mono', monospace; font-size: 10px; color: #55554f; letter-spacing: 0.1em; margin-bottom: 10px; }
  .val { font-family: 'Syne Variable', sans-serif; font-size: 17px; font-weight: 600; }
  .tags { display: flex; flex-wrap: wrap; gap: 7px; }
  .tag { font-family: 'Space Mono', monospace; font-size: 10.5px; border: 1px solid #2a2a26; padding: 5px 9px; color: #cfcdc4; }
  .h { font-family: 'Syne Variable', sans-serif; font-size: 26px; font-weight: 700; margin: 0 0 14px; }
  .ov { font-family: 'Syne Variable', sans-serif; font-size: 17px; line-height: 1.65; color: #cfcdc4; margin: 0 0 30px; }
  .features { border-top: 1px solid #1d1d1a; }
  .feat { display: flex; gap: 14px; align-items: baseline; padding: 13px 0; border-bottom: 1px solid #1d1d1a; }
  .feat-n { color: #ccff00; font-family: 'Space Mono', monospace; font-size: 11px; }
  .feat-t { font-family: 'Syne Variable', sans-serif; font-size: 16px; color: #cfcdc4; line-height: 1.4; }
  .next { margin-top: 50px; padding-top: 26px; border-top: 1px solid #1d1d1a; }
  .next-a { display: inline-block; color: #f2f0ea; text-decoration: none; font-family: 'Syne Variable', sans-serif; font-size: clamp(24px, 3vw, 42px); font-weight: 800; letter-spacing: -0.02em; }
  .ov + .h { margin-top: 30px; }

  /* ---------------- responsive ---------------- */
  @media (max-width: 680px) {
    main { padding: 32px 16px 90px; }
    .name { font-size: clamp(34px, 13vw, 80px); white-space: normal; }
    .tagline { font-size: clamp(17px, 5vw, 24px); }
    .actions { gap: 10px; }
    .btn-acid, .btn-ghost { flex: 1 1 auto; text-align: center; }
    .shot-main { margin-bottom: 44px; }
    .next-a { display: block; font-size: clamp(19px, 5.6vw, 26px); overflow-wrap: anywhere; }
  }
</style>
