---
import { getCollection } from 'astro:content';
import type { Lang } from '../../i18n/ui';
import { useTranslations, localizePath } from '../../i18n/utils';
import { patterns } from '../../lib/patterns';
import { formatDate } from '../../lib/date';

const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);

const posts = (await getCollection('blog', (e) => e.data.lang === lang)).sort(
  (a, b) => a.data.order - b.data.order,
);
---
<main>
  <div class="g-bloghead head">
    <div class="kicker">{t('blog.kicker')}</div>
    <div>
      <h1 class="title">{t('blog.title')}</h1>
      <p class="lead">{t('blog.lead')}</p>
    </div>
  </div>
  <div class="list">
    {posts.map((post, i) => (
      <a
        class="g-post post row-hl"
        href={localizePath(`/blog/${post.data.slug}`, lang)}
        data-preview
        data-img={`/og/${lang}/${post.data.slug}.png`}
        data-pattern={patterns[i % patterns.length]}
        data-label={post.data.tag}
      >
        <span
          class="post-thumb"
          aria-hidden="true"
          style={`background-image:url("/og/${lang}/${post.data.slug}.png")`}
        ></span>
        <span class="post-n">/0{i + 1}</span>
        <span class="post-title">{post.data.title}</span>
        <span class="post-tag">{post.data.tag}</span>
        <span class="post-date">{formatDate(post.data.date, lang)} →</span>
      </a>
    ))}
  </div>
</main>

<style>
  main { max-width: 1400px; margin: 0 auto; padding: 60px 26px 100px; min-height: 90vh; position: relative; z-index: 2; }
  .head { border-bottom: 1px solid #1d1d1a; padding-bottom: 30px; margin-bottom: 10px; }
  .kicker { font-family: 'Space Mono', monospace; font-size: 12px; color: #ccff00; }
  .title { font-family: 'Syne Variable', sans-serif; font-weight: 800; font-size: clamp(40px, 7vw, 96px); margin: 0 0 16px; letter-spacing: -0.03em; line-height: 0.92; }
  .lead { font-family: 'Syne Variable', sans-serif; font-size: clamp(16px, 1.8vw, 22px); color: #a8a69d; max-width: 520px; margin: 0; line-height: 1.4; }
  .list { border-top: 1px solid #2a2a26; margin-top: 30px; }
  .post { padding: 24px 8px; border-bottom: 1px solid #1d1d1a; color: #f2f0ea; text-decoration: none; }
  .post-n { font-family: 'Space Mono', monospace; font-size: 12px; }
  .post-title { font-family: 'Syne Variable', sans-serif; font-size: clamp(20px, 2.6vw, 38px); font-weight: 700; letter-spacing: -0.02em; line-height: 1.05; }
  .post-tag { font-family: 'Space Mono', monospace; font-size: 10.5px; opacity: 0.75; }
  .post-date { font-family: 'Space Mono', monospace; font-size: 11px; text-align: right; white-space: nowrap; }
  /* inline thumbnail — only shown on touch/mobile where the hover preview is unavailable */
  .post-thumb { display: none; }

  /* ---------------- responsive ---------------- */
  @media (max-width: 680px) {
    main { padding: 40px 16px 90px; }
    .title { font-size: clamp(34px, 12vw, 64px); }
    .post.g-post { display: flex; flex-direction: column; align-items: flex-start; gap: 4px; padding: 16px 2px 22px; }
    .post-thumb {
      display: block;
      order: 0;
      width: 100%;
      aspect-ratio: 1200 / 630;
      border: 1px solid #1d1d1a;
      background-size: cover;
      background-position: top center;
      margin-bottom: 13px;
    }
    .post-n { order: 1; }
    .post-title { order: 2; font-size: clamp(22px, 6.4vw, 32px); }
    .post.g-post .post-tag { display: block; order: 3; margin-top: 2px; }
    .post-date { order: 4; text-align: left; margin-top: 2px; }
  }
</style>
