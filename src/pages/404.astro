---
import Layout from '../layouts/Layout.astro';

const lang = 'es' as const;
---
<Layout
  lang={lang}
  path="/404"
  title="404 — Página no encontrada | Alex Alvarez Almendros"
  description="La página que buscas no existe o se ha movido."
>
  <main class="nf">
    <div class="nf-in">
      <span class="kicker">// ERROR 404</span>
      <div class="code" data-fit data-max="320">404</div>
      <p class="msg">Esta ruta no existe o se ha movido.<br /><span class="en">This page doesn’t exist or has moved.</span></p>
      <div class="actions">
        <a class="btn-acid" href="/">← Volver al inicio</a>
        <a class="btn-ghost" href="/en">Home (EN)</a>
      </div>
    </div>
  </main>

  <style>
    .nf { position: relative; z-index: 2; max-width: 1400px; margin: 0 auto; padding: 80px 26px 120px; min-height: 60vh; display: flex; align-items: center; }
    .nf-in { width: 100%; border-top: 1px solid #1d1d1a; padding-top: 40px; }
    .kicker { font-family: 'Space Mono', monospace; font-size: 12px; color: #ccff00; }
    .code { font-family: 'Syne Variable', sans-serif; font-weight: 800; font-size: clamp(96px, 30vw, 320px); line-height: 0.86; letter-spacing: -0.03em; color: transparent; -webkit-text-stroke: 2px #f2f0ea; margin: 16px 0 24px; white-space: nowrap; }
    .msg { font-family: 'Syne Variable', sans-serif; font-size: clamp(18px, 2.4vw, 28px); font-weight: 500; color: #dad8ce; line-height: 1.4; margin: 0 0 34px; }
    .msg .en { color: #55554f; font-size: 0.8em; }
    .actions { display: flex; gap: 12px; flex-wrap: wrap; }
    .btn-acid { background: #ccff00; color: #070706; font-family: 'Space Mono', monospace; font-weight: 700; font-size: 12.5px; letter-spacing: 0.04em; padding: 15px 22px; text-decoration: none; }
    .btn-ghost { background: transparent; color: #f2f0ea; border: 1px solid #2a2a26; font-family: 'Space Mono', monospace; font-size: 12.5px; padding: 15px 22px; text-decoration: none; }
    .btn-ghost:hover { border-color: #ccff00; color: #ccff00; }
    @media (max-width: 680px) { .nf { padding: 60px 16px 90px; } }
  </style>
</Layout>
