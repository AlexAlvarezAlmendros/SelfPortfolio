---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import ProjectView from '../../../components/views/ProjectView.astro';
import { projectShot } from '../../../lib/project-thumbs';
import { projectJsonLd } from '../../../lib/jsonld';

const lang = 'en' as const;

export async function getStaticPaths() {
  const projects = await getCollection('projects', (e) => e.data.lang === 'en');
  return projects.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const path = `/work/${d.slug}`;
const url = new URL(`/en${path}`, Astro.site).href;
const title = `${d.name} — ${d.label} | Alex Alvarez Almendros`;
const ogImage = projectShot[d.slug] ?? undefined;
---
<Layout
  lang={lang}
  path={path}
  title={title}
  description={d.tagline}
  ogType="article"
  ogImage={ogImage}
  tags={d.tags}
  jsonLd={projectJsonLd({ lang, url, name: d.name, description: d.tagline, image: ogImage, tags: d.tags, year: d.year, live: d.live, repo: d.repo })}
>
  <ProjectView lang={lang} entry={entry} />
</Layout>
