---
import Layout from '../../../layouts/Layout.astro';
import BlogListView from '../../../components/views/BlogListView.astro';
import { useTranslations } from '../../../i18n/utils';

const lang = 'en' as const;
const t = useTranslations(lang);
---
<Layout lang={lang} path="/blog" title={t('meta.blog.title')} description={t('meta.blog.desc')}>
  <BlogListView lang={lang} />
</Layout>
